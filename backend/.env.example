# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-this-secret-key-in-production-min-32-chars
APP_ACCESS_TOKEN_EXPIRE_MINUTES=480
APP_ALGORITHM=HS256
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
# SQLite (default – local dev)
DATABASE_URL=sqlite+aiosqlite:///./data/intercom.db

# PostgreSQL (uncomment and fill in for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/intercom

# ─── Admin seed account (created on first run) ─────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@local.host

# ─── Local server ──────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_IP=192.168.31.132

# ─── Asterisk integration ──────────────────────────────────────────────────────
ASTERISK_MODE=local                      # local | ssh | ami
ASTERISK_PJSIP_CONF=/etc/asterisk/pjsip.conf
ASTERISK_EXTENSIONS_CONF=/etc/asterisk/extensions.conf
# Files written exclusively by intercom-server (add #include in main confs):
ASTERISK_PJSIP_WEBRTC_CONF=/etc/asterisk/pjsip_webrtc.conf
ASTERISK_EXTENSIONS_APARTMENTS_CONF=/etc/asterisk/extensions_apartments.conf
ASTERISK_RELOAD_CMD=

# ─── Asterisk AMI (Manager Interface) ─────────────────────────────────────────
ASTERISK_AMI_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=intercom
ASTERISK_AMI_SECRET=intercom-ami-secret

# ─── Cloud SIP trunk ──────────────────────────────────────────────────────────
CLOUD_SIP_TRUNK_ENDPOINT=

# ─── Cloud WebSocket bridge ───────────────────────────────────────────────────
# Outgoing persistent WS to cloud device_service. Leave empty to disable.
CLOUD_WS_URL=
CLOUD_BRIDGE_TOKEN=

# ─── WebRTC ───────────────────────────────────────────────────────────────────
# Returned to mobile apps in provision_webrtc_endpoint ack so SIP.js/PJSIP can
# discover NAT-traversal candidates over the LAN.
INTERCOM_STUN_URL=stun:192.168.31.132:3478

# Public base URL of this server. Used to build go2rtc video links sent to
# the cloud in call_started. Empty → defaults to https://${SERVER_IP}
INTERCOM_PUBLIC_BASE_URL=

# ─── Mobile media_config (advertised to cloud in WS hello) ────────────────────
# Public host/IP of the bridge as reachable by mobile clients.
PUBLIC_BRIDGE_HOST=bridge.example.com

# Internal go2rtc REST API URL (backend uses this to register RTSP streams).
# go2rtc runs in network_mode: host → use the host IP:1984.
GO2RTC_API_URL=http://192.168.31.132:1984

# WHEP basic-auth for go2rtc (if enabled).
GO2RTC_USER=viewer
GO2RTC_PASS=somesecret

# TURN (coturn) — used in media_config.ice_servers.
COTURN_PUBLIC_HOST=bridge.example.com
COTURN_PORT=3478
COTURN_USER=u
COTURN_CRED=p

# Short-lived TURN credentials via coturn use-auth-secret mode (recommended for prod).
# Set to the same value as coturn's `static-auth-secret`.
# When set, COTURN_USER/COTURN_CRED are ignored — ephemeral HMAC-SHA1 creds
# are generated with a 15 min TTL and refreshed every 10 min via media_config_loop.
COTURN_SECRET=changeme-turn-secret

# SIP-over-WSS endpoint and SIP realm advertised to mobile clients.
# Leave SIP_WS_URL empty to default to wss://${PUBLIC_BRIDGE_HOST}/asterisk/ws
SIP_WS_URL=
SIP_DOMAIN=bridge.local

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
