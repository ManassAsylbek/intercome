# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-this-secret-key-in-production-min-32-chars
APP_ACCESS_TOKEN_EXPIRE_MINUTES=480
APP_ALGORITHM=HS256
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
# SQLite (default – local dev)
DATABASE_URL=sqlite+aiosqlite:///./data/intercom.db

# PostgreSQL (uncomment and fill in for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/intercom

# ─── Admin seed account (created on first run) ─────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@local.host

# ─── Local server ──────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_IP=192.168.31.132

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
