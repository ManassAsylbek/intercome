# ─── Intercom Management Server — настройки окружения ─────────────────────────
# Скопируйте этот файл в .env и заполните под ваш сервер:
#   cp .env.example .env

# ─── Сервер ────────────────────────────────────────────────────────────────────
# IP этого сервера (устройства будут подключаться по нему)
SERVER_IP=192.168.50.132

# Порт фронтенда (по умолчанию 80 для Docker)
FRONTEND_PORT=80

# ─── Приложение ────────────────────────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=change-me-to-a-random-32-char-string!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# CORS: добавьте IP всех хостов с которых открывается браузер
APP_CORS_ORIGINS=http://localhost,http://localhost:80,http://192.168.50.132,http://192.168.50.132:80

# ─── Asterisk ──────────────────────────────────────────────────────────────────
# local  — Asterisk на том же сервере
# ssh    — Asterisk на другом сервере (заполните SSH-параметры ниже)
ASTERISK_MODE=local
ASTERISK_PJSIP_CONF=/etc/asterisk/pjsip.conf
ASTERISK_RELOAD_CMD=sudo systemctl restart asterisk

# SSH (нужно только при ASTERISK_MODE=ssh)
ASTERISK_SSH_HOST=
ASTERISK_SSH_PORT=22
ASTERISK_SSH_USER=
ASTERISK_SSH_KEY_FILE=
